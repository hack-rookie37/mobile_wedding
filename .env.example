# ── 필수 ────────────────────────────────────────────────────────────────────
# Supabase 프로젝트의 URL과 anon(publishable) 키.
# 로컬 개발: `supabase start` 후 `supabase status -o env`의 API_URL / ANON_KEY.
# 클라우드: 프로젝트 대시보드 → Settings → API.
# service role 키는 이 앱 어디에서도 사용하지 않는다 (ADR-006) — 추가하지 말 것.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 선택: AI 도우미 ─────────────────────────────────────────────────────────
# 미설정이면 AI 버튼만 '미설정' 안내를 띄우고 편집기는 완전히 동작한다.
# AI_PROVIDER=mock  → 결정적 mock provider (e2e·로컬 데모용, 네트워크 없음)
# 실제 모델: ANTHROPIC_API_KEY와 AI_MODEL(예: claude-sonnet-5)을 함께 설정.
# 두 값은 서버 전용이다 — NEXT_PUBLIC_ 접두사를 붙이지 말 것.
#AI_PROVIDER=mock
#ANTHROPIC_API_KEY=
#AI_MODEL=
