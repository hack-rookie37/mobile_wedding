# ── 필수 ────────────────────────────────────────────────────────────────────
# Supabase 프로젝트의 URL과 anon(publishable) 키.
# 로컬 개발: `supabase start` 후 `supabase status -o env`의 API_URL / ANON_KEY.
# 클라우드: 프로젝트 대시보드 → Settings → API.
# service role 키는 이 앱 어디에서도 사용하지 않는다 (ADR-006) — 추가하지 말 것.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── 선택: AI 도우미 ─────────────────────────────────────────────────────────
# 미설정이면 AI 버튼만 '미설정' 안내를 띄우고 편집기는 완전히 동작한다.
# AI_PROVIDER=mock  → 결정적 mock provider (e2e·로컬 데모용, 네트워크 없음)
# 실제 모델: ANTHROPIC_API_KEY와 AI_MODEL(예: claude-sonnet-5)을 함께 설정.
# 두 값은 서버 전용이다 — NEXT_PUBLIC_ 접두사를 붙이지 말 것.
#AI_PROVIDER=mock
#ANTHROPIC_API_KEY=
#AI_MODEL=

# 카카오톡 공유 (선택) — 공유하기 섹션의 '카카오톡 공유' 버튼에 필요하다.
# 없으면 게스트 화면에 '링크 복사'만 나온다 (버튼이 조용히 실패하지 않는다).
# 발급: developers.kakao.com → 앱 만들기 → 앱 키의 JavaScript 키.
# 플랫폼 > Web에 배포 도메인을 등록해야 공유가 동작한다.
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── 도메인 루트에 걸 청첩장 ─────────────────────────────────────────────────
# 루트(https://도메인/)가 보여줄 발행본의 공개 주소(slug).
# 발행 자체는 예전처럼 /i/<slug>에 하고, 그중 하나를 여기서 대표로 고른다.
# 미설정이면 루트는 즉시 에러를 낸다 — 하객이 빈 화면을 보는 것보다 낫다.
NEXT_PUBLIC_INVITATION_SLUG=
